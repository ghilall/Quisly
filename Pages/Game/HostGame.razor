@page "/host-game/{SessionId}"
@using Quisly.Services
@using Quisly.Models
@using Quisly.Components
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject GameService Game
@inject RealtimeService Realtime
@inject AuthService Auth
@inject NavigationManager Nav

<div class="host-game-page">
    @if (_loading)
    {
        <div class="waiting-phase">
            <div class="spinner"></div>
            <p>Loading...</p>
        </div>
    }
    else if (_sessionNotFound)
    {
        <div class="waiting-phase">
            <h2>Game not found</h2>
            <p>This session may have ended.</p>
            <button class="btn-primary btn-large" @onclick='() => Nav.NavigateTo("/")'>Back to Home</button>
        </div>
    }
    else if (_currentQuestion != null)
    {
        @switch (_phase)
        {
            case GamePhase.ShowingQuestion:
                <div class="question-display">
                    <div class="question-header-bar">
                        <span class="question-counter">@(_currentIndex + 1) / @_questions.Count</span>
                        <CountdownTimer TotalSeconds="@_currentQuestion.TimeLimitSeconds"
                                        OnTick="HandleTick"
                                        OnTimeUp="HandleTimeUp" />
                    </div>
                    <h2 class="question-text">@_currentQuestion.QuestionText</h2>
                    <div class="answer-grid">
                        <GameButton Text="@_currentQuestion.OptionA" Color="red" Icon="▲"
                                    IsSelected="@(_selectedAnswer == "A")"
                                    IsDisabled="@_answeredByHost"
                                    OnClick="@(() => SubmitHostAnswer("A"))" />
                        <GameButton Text="@_currentQuestion.OptionB" Color="blue" Icon="◆"
                                    IsSelected="@(_selectedAnswer == "B")"
                                    IsDisabled="@_answeredByHost"
                                    OnClick="@(() => SubmitHostAnswer("B"))" />
                        <GameButton Text="@_currentQuestion.OptionC" Color="yellow" Icon="●"
                                    IsSelected="@(_selectedAnswer == "C")"
                                    IsDisabled="@_answeredByHost"
                                    OnClick="@(() => SubmitHostAnswer("C"))" />
                        <GameButton Text="@_currentQuestion.OptionD" Color="green" Icon="■"
                                    IsSelected="@(_selectedAnswer == "D")"
                                    IsDisabled="@_answeredByHost"
                                    OnClick="@(() => SubmitHostAnswer("D"))" />
                    </div>
                    <div class="answer-count">
                        <span>@_answeredCount / @_players.Count answered</span>
                    </div>
                </div>
                break;

            case GamePhase.ShowingResults:
                <div class="results-display">
                    <h2>Results</h2>
                    <div class="answer-bars">
                        <div class="answer-bar bar-red">
                            <span class="bar-label">▲ @_currentQuestion.OptionA</span>
                            <div class="bar-fill" style="width: @GetAnswerPercentage("A")%">
                                @if (_currentQuestion.CorrectOption == "A") { <span class="correct-mark">✓</span> }
                            </div>
                        </div>
                        <div class="answer-bar bar-blue">
                            <span class="bar-label">◆ @_currentQuestion.OptionB</span>
                            <div class="bar-fill" style="width: @GetAnswerPercentage("B")%">
                                @if (_currentQuestion.CorrectOption == "B") { <span class="correct-mark">✓</span> }
                            </div>
                        </div>
                        <div class="answer-bar bar-yellow">
                            <span class="bar-label">● @_currentQuestion.OptionC</span>
                            <div class="bar-fill" style="width: @GetAnswerPercentage("C")%">
                                @if (_currentQuestion.CorrectOption == "C") { <span class="correct-mark">✓</span> }
                            </div>
                        </div>
                        <div class="answer-bar bar-green">
                            <span class="bar-label">■ @_currentQuestion.OptionD</span>
                            <div class="bar-fill" style="width: @GetAnswerPercentage("D")%">
                                @if (_currentQuestion.CorrectOption == "D") { <span class="correct-mark">✓</span> }
                            </div>
                        </div>
                    </div>
                    <button class="btn-primary btn-large" @onclick="ShowLeaderboard">Show Leaderboard</button>
                </div>
                break;

            case GamePhase.Leaderboard:
                <div class="leaderboard-phase">
                    <Leaderboard Players="_players" />
                    @if (_currentIndex < _questions.Count - 1)
                    {
                        <button class="btn-primary btn-large" @onclick="NextQuestion">Next Question</button>
                    }
                    else
                    {
                        <button class="btn-primary btn-large" @onclick="ShowFinalResults">Show Final Results</button>
                    }
                </div>
                break;
        }
    }

    @if (_phase == GamePhase.FinalResults)
    {
        <div class="final-results">
            <h1 class="final-title">Game Over!</h1>
            <Podium Players="_players" />
            <Leaderboard Players="_players" />
            <button class="btn-primary btn-large" @onclick='() => Nav.NavigateTo("/")'>Back to Home</button>
        </div>
    }
</div>

@code {
    [Parameter] public string SessionId { get; set; } = "";

    private List<Question> _questions = new();
    private List<Player> _players = new();
    private Question? _currentQuestion;
    private GameSession? _session;
    private int _currentIndex;
    private int _answeredCount;
    private bool _loading = true;
    private bool _sessionNotFound;
    private GamePhase _phase = GamePhase.ShowingQuestion;
    private DotNetObjectReference<HostGame>? _selfRef;
    private CancellationTokenSource? _pollCts;

    private string? _hostPlayerId;
    private DateTime _questionStartTime;
    private int _secondsLeft;
    private bool _answeredByHost;
    private string? _selectedAnswer;
    private bool _hostXpAwarded;

    private enum GamePhase { ShowingQuestion, ShowingResults, Leaderboard, FinalResults }

    protected override async Task OnInitializedAsync()
    {
        _selfRef = DotNetObjectReference.Create(this);
        _session = await Game.GetSessionById(SessionId);
        if (_session == null)
        {
            _sessionNotFound = true;
            _loading = false;
            return;
        }

        // Ensure host is also a player (so they can answer and appear in leaderboard).
        if (Auth.CurrentUser?.Id != null)
        {
            var profile = await Auth.GetCurrentProfile();
            var nickname = string.IsNullOrWhiteSpace(profile?.Username) ? "Host" : profile!.Username;
            var hostPlayer = await Game.EnsurePlayerForUser(SessionId, Auth.CurrentUser.Id, nickname);
            _hostPlayerId = hostPlayer.Id;
        }

        _questions = await Game.GetQuizQuestions(_session.QuizId);
        _currentIndex = Math.Max(0, Math.Min(_session.CurrentQuestionIndex, Math.Max(0, _questions.Count - 1)));
        _currentQuestion = _questions.Count > 0 ? _questions[_currentIndex] : null;

        _players = await Game.GetSessionPlayers(SessionId);
        _answeredCount = _players.Count(p => p.LastAnswer != null);

        _phase = _session.Status switch
        {
            SessionStatus.ShowingResults => GamePhase.ShowingResults,
            SessionStatus.Leaderboard => GamePhase.Leaderboard,
            SessionStatus.Finished => GamePhase.FinalResults,
            _ => GamePhase.ShowingQuestion
        };
        if (_phase == GamePhase.FinalResults)
            _ = AwardHostXpOnceAsync();

        _questionStartTime = DateTime.UtcNow;
        _secondsLeft = _currentQuestion?.TimeLimitSeconds ?? 0;

        // Realtime may no-op (offline/DNS); polling keeps the game responsive.
        await Realtime.SubscribeToPlayers(SessionId, _selfRef);
        await Realtime.SubscribeToSession(SessionId, _selfRef);
        _pollCts = new CancellationTokenSource();
        _ = PollLoopAsync(_pollCts.Token);
        _loading = false;
    }

    [JSInvokable]
    public async Task OnPlayersChanged()
    {
        await InvokeAsync(async () =>
        {
            _players = await Game.GetSessionPlayers(SessionId);
            _answeredCount = _players.Count(p => p.LastAnswer != null);
            if (_phase == GamePhase.ShowingQuestion && _players.Count > 0 && _answeredCount >= _players.Count)
            {
                await TransitionToResultsAsync();
            }
            StateHasChanged();
        });
    }

    [JSInvokable]
    public async Task OnSessionStatusChanged(string status)
    {
        await InvokeAsync(() =>
        {
            if (status == SessionStatus.ShowingResults) _phase = GamePhase.ShowingResults;
            else if (status == SessionStatus.Leaderboard) _phase = GamePhase.Leaderboard;
            else if (status == SessionStatus.Finished) _phase = GamePhase.FinalResults;
            else if (status == SessionStatus.ShowingQuestion) _phase = GamePhase.ShowingQuestion;
            StateHasChanged();
        });
    }

    private void HandleTick(int secondsLeft)
    {
        _secondsLeft = secondsLeft;
    }

    private async Task HandleTimeUp()
    {
        if (_phase != GamePhase.ShowingQuestion) return;
        await TransitionToResultsAsync();
    }

    private async Task TransitionToResultsAsync()
    {
        await ScoreCurrentQuestion();
        _phase = GamePhase.ShowingResults;
        await Game.UpdateSessionStatus(SessionId, SessionStatus.ShowingResults, _currentIndex);
        StateHasChanged();
    }

    private async Task ScoreCurrentQuestion()
    {
        if (_currentQuestion == null) return;

        foreach (var player in _players)
        {
            bool correct = player.LastAnswer == _currentQuestion.CorrectOption;
            int score = Game.CalculateScore(
                player.LastAnswer ?? "",
                _currentQuestion.CorrectOption,
                player.LastAnswerTimeMs ?? _currentQuestion.TimeLimitSeconds * 1000,
                _currentQuestion.TimeLimitSeconds,
                _currentQuestion.Points,
                player.CurrentStreak);

            await Game.UpdatePlayerScore(player.Id, score, correct);
        }

        _players = await Game.GetSessionPlayers(SessionId);
    }

    private void ShowLeaderboard()
    {
        _phase = GamePhase.Leaderboard;
        _ = Game.UpdateSessionStatus(SessionId, SessionStatus.Leaderboard, _currentIndex);
    }

    private async Task NextQuestion()
    {
        _currentIndex++;
        _currentQuestion = _questions[_currentIndex];
        _answeredCount = 0;
        _phase = GamePhase.ShowingQuestion;
        _questionStartTime = DateTime.UtcNow;
        _secondsLeft = _currentQuestion.TimeLimitSeconds;
        _answeredByHost = false;
        _selectedAnswer = null;

        await Game.ResetAnswers(SessionId);
        _players = await Game.GetSessionPlayers(SessionId);

        await Game.UpdateSessionStatus(SessionId, SessionStatus.ShowingQuestion, _currentIndex);
    }

    private async Task ShowFinalResults()
    {
        _phase = GamePhase.FinalResults;
        await Game.UpdateSessionStatus(SessionId, SessionStatus.Finished);
        _ = AwardHostXpOnceAsync();
    }

    private int GetAnswerPercentage(string option)
    {
        if (_players.Count == 0) return 0;
        int count = _players.Count(p => p.LastAnswer == option);
        return (int)((double)count / _players.Count * 100);
    }

    public async ValueTask DisposeAsync()
    {
        try { _pollCts?.Cancel(); } catch { }
        _pollCts?.Dispose();
        await Realtime.UnsubscribeAll();
        _selfRef?.Dispose();
    }

    private async Task SubmitHostAnswer(string answer)
    {
        if (_answeredByHost || _hostPlayerId == null || _currentQuestion == null) return;

        _selectedAnswer = answer;
        _answeredByHost = true;

        var elapsed = (int)(DateTime.UtcNow - _questionStartTime).TotalMilliseconds;
        await Game.SubmitAnswer(_hostPlayerId, SessionId, answer, elapsed);

        // Refresh counts quickly after host answers.
        await OnPlayersChanged();
    }

    private async Task PollLoopAsync(CancellationToken token)
    {
        var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await timer.WaitForNextTickAsync(token))
            {
                var session = await Game.GetSessionById(SessionId);
                if (session == null) continue;

                if (_session == null || session.Status != _session.Status || session.CurrentQuestionIndex != _session.CurrentQuestionIndex)
                {
                    _session = session;
                    _phase = session.Status switch
                    {
                        SessionStatus.ShowingResults => GamePhase.ShowingResults,
                        SessionStatus.Leaderboard => GamePhase.Leaderboard,
                        SessionStatus.Finished => GamePhase.FinalResults,
                        _ => GamePhase.ShowingQuestion
                    };
                    if (_phase == GamePhase.FinalResults)
                        _ = AwardHostXpOnceAsync();

                    if (session.CurrentQuestionIndex != _currentIndex && _questions.Count > 0)
                    {
                        _currentIndex = Math.Max(0, Math.Min(session.CurrentQuestionIndex, _questions.Count - 1));
                        _currentQuestion = _questions[_currentIndex];
                        _questionStartTime = DateTime.UtcNow;
                        _secondsLeft = _currentQuestion.TimeLimitSeconds;
                        _answeredByHost = false;
                        _selectedAnswer = null;
                    }
                }

                _players = await Game.GetSessionPlayers(SessionId);
                _answeredCount = _players.Count(p => p.LastAnswer != null);

                if (_phase == GamePhase.ShowingQuestion && _players.Count > 0 && _answeredCount >= _players.Count)
                {
                    await TransitionToResultsAsync();
                }

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
        finally { timer.Dispose(); }
    }

    private async Task AwardHostXpOnceAsync()
    {
        if (_hostXpAwarded) return;
        if (_hostPlayerId == null) return;

        _hostXpAwarded = true;
        try
        {
            // Players are already ordered by score desc.
            _players = await Game.GetSessionPlayers(SessionId);
            var idx = _players.FindIndex(p => p.Id == _hostPlayerId);
            var rank = idx >= 0 ? idx + 1 : 99;
            await Auth.AwardGameXp(rank);
        }
        catch
        {
            // Non-critical; avoid breaking the host screen if XP award fails.
            _hostXpAwarded = false;
        }
    }
}
