@page "/lobby/{SessionId}"
@using Quisly.Services
@using Quisly.Models
@using Quisly.Components
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject GameService Game
@inject RealtimeService Realtime
@inject AuthService Auth
@inject NavigationManager Nav

<div class="lobby-page">
    <div class="lobby-header">
        <h1 class="brand-title">Quisly</h1>
        <p class="lobby-subtitle">Waiting for players to join...</p>
    </div>

    <div class="lobby-content">
        <div class="lobby-join-info">
            <PinDisplay Pin="@_pin" />
            <QRCodeDisplay JoinUrl="@JoinUrl" />
            <p class="join-url">@JoinUrl</p>
        </div>

        <div class="lobby-players">
            <h2>Players (@_players.Count)</h2>
            @if (_isHost)
            {
                <AvatarPicker @bind-SelectedAvatarId="HostAvatarId" />
                <div class="form-group" style="max-width:420px;margin:16px auto 0;">
                    <label>Your name (host)</label>
                    <input type="text"
                           class="form-input"
                           @bind="HostNickname"
                           @bind:event="oninput"
                           placeholder="Host"
                           disabled="@(_savingHostName || _savingHostAvatar)" />
                </div>
            }
            <div class="player-grid">
                @foreach (var player in _players)
                {
                    <div class="player-bubble animate-pop">
                        <img class="avatar-img" src="@AvatarCatalog.Url(player.AvatarId)" alt="Avatar" />
                        <span class="player-name">@player.Nickname</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="lobby-actions">
        <button class="btn-primary btn-large"
                @onclick="StartGame"
                disabled="@(_players.Count == 0)">
            Start Game (@_players.Count players)
        </button>
    </div>
</div>

@code {
    [Parameter] public string SessionId { get; set; } = "";

    private string _pin = "";
    private List<Player> _players = new();
    private DotNetObjectReference<Lobby>? _selfRef;
    private CancellationTokenSource? _pollCts;
    private bool _disposed;
    private string JoinUrl => $"{Nav.BaseUri}join/{_pin}";
    private bool _isHost;
    private string _hostNickname = "";
    private string? _hostPlayerId;
    private string _hostAvatarId = "cat_lady";
    private bool _savingHostAvatar;
    private bool _savingHostName;
    private CancellationTokenSource? _hostNameDebounceCts;
    private CancellationTokenSource? _hostAvatarDebounceCts;

    protected override async Task OnInitializedAsync()
    {
        _selfRef = DotNetObjectReference.Create(this);
        var session = await Game.GetSessionById(SessionId);
        if (_disposed) return;
        if (session != null)
            _pin = session.Pin;

        // Make sure the host is also a player so they appear in the lobby list.
        if (session != null && Auth.CurrentUser?.Id != null && session.HostId == Auth.CurrentUser.Id)
        {
            _isHost = true;
            var profile = await Auth.GetCurrentProfile();
            var nickname = string.IsNullOrWhiteSpace(profile?.Username) ? "Host" : profile!.Username;
            var hostPlayer = await Game.EnsurePlayerForUser(SessionId, Auth.CurrentUser.Id, nickname);
            if (_disposed) return;
            _hostPlayerId = hostPlayer.Id;
            _hostNickname = hostPlayer.Nickname;
            _hostAvatarId = string.IsNullOrWhiteSpace(hostPlayer.AvatarId) ? "cat_lady" : hostPlayer.AvatarId;
        }

        await LoadPlayers();
        if (_disposed) return;

        try
        {
            if (_selfRef != null)
                await Realtime.SubscribeToPlayers(SessionId, _selfRef);
        }
        catch (ObjectDisposedException)
        {
            // Component was disposed during async init/navigation.
            return;
        }

        _pollCts = new CancellationTokenSource();
        _ = PollLoopAsync(_pollCts.Token);
    }

    [JSInvokable]
    public async Task OnPlayersChanged()
    {
        await InvokeAsync(async () =>
        {
            await LoadPlayers();
            StateHasChanged();
        });
    }

    private async Task LoadPlayers()
    {
        _players = await Game.GetSessionPlayers(SessionId);
    }

    private string HostNickname
    {
        get => _hostNickname;
        set
        {
            if (_hostNickname == value) return;
            _hostNickname = value;
            _ = DebouncedSaveHostNameAsync(value);
        }
    }

    private string HostAvatarId
    {
        get => _hostAvatarId;
        set
        {
            if (_hostAvatarId == value) return;
            _hostAvatarId = value;
            _ = DebouncedSaveHostAvatarAsync(value);
        }
    }

    private async Task DebouncedSaveHostNameAsync(string name)
    {
        if (!_isHost || _hostPlayerId == null) return;
        var trimmed = (name ?? "").Trim();
        if (string.IsNullOrWhiteSpace(trimmed)) return;

        try
        {
            _hostNameDebounceCts?.Cancel();
            _hostNameDebounceCts?.Dispose();
            _hostNameDebounceCts = new CancellationTokenSource();
            var token = _hostNameDebounceCts.Token;

            await Task.Delay(500, token);

            _savingHostName = true;
            await Game.UpdatePlayerNickname(_hostPlayerId, trimmed);
            await LoadPlayers();
        }
        catch (OperationCanceledException) { }
        finally
        {
            _savingHostName = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task DebouncedSaveHostAvatarAsync(string avatarId)
    {
        if (!_isHost || _hostPlayerId == null) return;
        var trimmed = (avatarId ?? "").Trim();
        if (string.IsNullOrWhiteSpace(trimmed)) return;

        try
        {
            _hostAvatarDebounceCts?.Cancel();
            _hostAvatarDebounceCts?.Dispose();
            _hostAvatarDebounceCts = new CancellationTokenSource();
            var token = _hostAvatarDebounceCts.Token;

            await Task.Delay(200, token);

            _savingHostAvatar = true;
            await Game.UpdatePlayerAvatar(_hostPlayerId, trimmed);
            await LoadPlayers();
        }
        catch (OperationCanceledException) { }
        finally
        {
            _savingHostAvatar = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task StartGame()
    {
        await Game.UpdateSessionStatus(SessionId, SessionStatus.ShowingQuestion, 0);
        Nav.NavigateTo($"/host-game/{SessionId}");
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        try { _pollCts?.Cancel(); } catch { }
        _pollCts?.Dispose();
        try { _hostNameDebounceCts?.Cancel(); } catch { }
        _hostNameDebounceCts?.Dispose();
        try { _hostAvatarDebounceCts?.Cancel(); } catch { }
        _hostAvatarDebounceCts?.Dispose();
        await Realtime.UnsubscribeAll();
        _selfRef?.Dispose();
        _selfRef = null;
    }

    private async Task PollLoopAsync(CancellationToken token)
    {
        var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await timer.WaitForNextTickAsync(token))
            {
                if (_disposed) break;
                await LoadPlayers();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
        finally { timer.Dispose(); }
    }
}
