@page "/"
@using Quisly.Services
@using Quisly.Models
@using Quisly.Components
@inject AuthService Auth
@inject NavigationManager Nav

<div class="home-page">
    <header class="home-header">
        <h1 class="brand-title">Quisly</h1>
        @if (Auth.IsAuthenticated)
        {
            <PlayerMenu Profile="@_profile" OnProfileChanged="ReloadProfile" />
        }
    </header>

    <main class="home-main">
        @if (!Auth.IsAuthenticated)
        {
            <div class="hero-section">
                <h2>The Ultimate Quiz Experience</h2>
                <p>Host live quizzes, challenge friends, and climb the leaderboard!</p>
                <div class="hero-actions">
                    <button class="btn-primary btn-large" @onclick='() => Nav.NavigateTo("/login")'>Sign In</button>
                    <button class="btn-secondary btn-large" @onclick='() => Nav.NavigateTo("/register")'>Create Account</button>
                </div>
            </div>
        }
        else
        {
            <div class="action-cards">
                <!-- Host — Premium only -->
                <div class="action-card host-card @(!IsPremium ? "locked-card" : "")"
                     @onclick="TryHost">
                    <div class="card-icon">🎮</div>
                    <h3>Host a Game</h3>
                    <p>Create a session and invite players</p>
                    @if (!IsPremium)
                    {
                        <span class="card-lock-badge">🔒 Premium</span>
                    }
                </div>

                <!-- Join — Free for everyone -->
                <div class="action-card join-card" @onclick='() => Nav.NavigateTo("/join")'>
                    <div class="card-icon">🎯</div>
                    <h3>Join a Game</h3>
                    <p>Enter a PIN or scan a QR code</p>
                </div>

                <!-- Create Quiz — Premium only -->
                <div class="action-card create-card @(!IsPremium ? "locked-card" : "")"
                     @onclick="TryCreateQuiz">
                    <div class="card-icon">✏️</div>
                    <h3>Create Quiz</h3>
                    <p>Build your own quiz questions</p>
                    @if (!IsPremium)
                    {
                        <span class="card-lock-badge">🔒 Premium</span>
                    }
                </div>
            </div>
        }
    </main>
</div>

<!-- Premium Gate Modal -->
<PremiumGateModal IsVisible="@_showPremiumModal"
                  FeatureName="@_gatedFeatureName"
                  OnClose="@(() => _showPremiumModal = false)"
                  OnUpgraded="ReloadProfile" />

@code {
    private Profile? _profile;
    private bool _showPremiumModal;
    private string _gatedFeatureName = "";

    private bool IsPremium => _profile?.IsPremium == true;

    protected override async Task OnInitializedAsync()
    {
        Auth.OnAuthStateChanged += OnAuthChanged;
        if (Auth.IsAuthenticated)
            _profile = await Auth.GetCurrentProfile();
    }

    private async void OnAuthChanged()
    {
        _profile = await Auth.GetCurrentProfile(forceRefresh: true);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ReloadProfile()
    {
        _profile = await Auth.GetCurrentProfile(forceRefresh: true);
        StateHasChanged();
    }

    private void TryHost()
    {
        if (IsPremium) Nav.NavigateTo("/host");
        else ShowPremiumGate("Host a Game");
    }

    private void TryCreateQuiz()
    {
        if (IsPremium) Nav.NavigateTo("/create-quiz");
        else ShowPremiumGate("Create Quiz");
    }

    private void ShowPremiumGate(string featureName)
    {
        _gatedFeatureName = featureName;
        _showPremiumModal = true;
    }

    public void Dispose()
    {
        Auth.OnAuthStateChanged -= OnAuthChanged;
    }
}
