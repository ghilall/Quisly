@namespace Quisly.Components
@using Quisly.Models

<div class="podium-container">
    @if (Players.Count >= 2)
    {
        <div class="podium-place second">
            <img class="avatar-img avatar-img-lg" src="@AvatarCatalog.Url(Players[1].AvatarId)" alt="Avatar" />
            <div class="podium-name">@Players[1].Nickname</div>
            <div class="podium-score">@Players[1].Score.ToString("N0")</div>
            <div class="podium-bar bar-2"></div>
        </div>
    }
    @if (Players.Count >= 1)
    {
        <div class="podium-place first">
            <img class="avatar-img avatar-img-lg" src="@AvatarCatalog.Url(Players[0].AvatarId)" alt="Avatar" />
            <div class="podium-name">@Players[0].Nickname</div>
            <div class="podium-score">@Players[0].Score.ToString("N0")</div>
            <div class="podium-bar bar-1"></div>
        </div>
    }
    @if (Players.Count >= 3)
    {
        <div class="podium-place third">
            <img class="avatar-img avatar-img-lg" src="@AvatarCatalog.Url(Players[2].AvatarId)" alt="Avatar" />
            <div class="podium-name">@Players[2].Nickname</div>
            <div class="podium-score">@Players[2].Score.ToString("N0")</div>
            <div class="podium-bar bar-3"></div>
        </div>
    }
</div>

@code {
    [Parameter] public List<Player> Players { get; set; } = new();
}
