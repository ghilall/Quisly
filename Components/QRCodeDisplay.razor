@namespace Quisly.Components
@using QRCoder

<div class="qr-container">
    <div class="qr-code">
        @if (!string.IsNullOrEmpty(_qrImageData))
        {
            <img src="@_qrImageData" alt="QR Code to join game" />
        }
    </div>
    <p class="qr-label">Scan to join!</p>
</div>

@code {
    [Parameter] public string JoinUrl { get; set; } = "";

    private string _qrImageData = "";

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(JoinUrl))
        {
            using var qrGenerator = new QRCodeGenerator();
            using var qrCodeData = qrGenerator.CreateQrCode(JoinUrl, QRCodeGenerator.ECCLevel.Q);
            using var pngByteQRCode = new PngByteQRCode(qrCodeData);
            var qrBytes = pngByteQRCode.GetGraphic(8);
            _qrImageData = $"data:image/png;base64,{Convert.ToBase64String(qrBytes)}";
        }
    }
}
